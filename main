-- Tab bar
local TabBar=mk("Frame",{Size=UDim2.new(1,0,0,38),Position=UDim2.new(0,0,0,46),BackgroundColor3=C.bg2},Win)
Instance.new("UIListLayout",TabBar).FillDirection=Enum.FillDirection.Horizontal
mk("Frame",{Size=UDim2.new(1,0,0,1),Position=UDim2.new(0,0,1,-1),BackgroundColor3=C.bord},TabBar)
local ContentArea=mk("Frame",{Size=UDim2.new(1,-18,1,-98),Position=UDim2.new(0,9,0,88),BackgroundTransparency=1},Win)

local tabs={}; local activeTab=nil; local TAB_N=7

local function makeTab(label,order)
    local btn=mk("TextButton",{Size=UDim2.new(1/TAB_N,0,1,0),BackgroundTransparency=1,Text=label,TextColor3=C.sub,TextSize=9,Font=Enum.Font.GothamBold,AutoButtonColor=false,LayoutOrder=order},TabBar)
    local bar=mk("Frame",{Size=UDim2.new(0,0,0,2),Position=UDim2.new(0.5,0,1,-2),BackgroundColor3=C.acc2},btn); cr(1,bar)
    local scroll=Instance.new("ScrollingFrame",ContentArea)
    scroll.Size=UDim2.new(1,0,1,0); scroll.BackgroundTransparency=1; scroll.BorderSizePixel=0
    scroll.ScrollBarThickness=3; scroll.ScrollBarImageColor3=C.acc; scroll.CanvasSize=UDim2.new(0,0,0,0)
    scroll.AutomaticCanvasSize=Enum.AutomaticSize.Y; scroll.Visible=false
    Instance.new("UIListLayout",scroll).Padding=UDim.new(0,5)
    local pp=Instance.new("UIPadding",scroll); pp.PaddingTop=UDim.new(0,4); pp.PaddingBottom=UDim.new(0,10)
    local tab={btn=btn,bar=bar,scroll=scroll,n=0}; tabs[label]=tab
    btn.MouseButton1Click:Connect(function()
        if activeTab then activeTab.scroll.Visible=false; tw(activeTab.btn,.15,{TextColor3=C.sub}); tw(activeTab.bar,.15,{Size=UDim2.new(0,0,0,2),Position=UDim2.new(0.5,0,1,-2)}) end
        activeTab=tab; scroll.Visible=true; tw(btn,.15,{TextColor3=C.txt}); tw(bar,.15,{Size=UDim2.new(0.7,0,0,2),Position=UDim2.new(0.15,0,1,-2)})
    end)
    return tab
end

-- ─── Components ───────────────────────────────────────────────
local function Sec(t,s) t.n+=1; local f=mk("Frame",{Size=UDim2.new(1,0,0,24),BackgroundTransparency=1,LayoutOrder=t.n},t.scroll); mk("Frame",{Size=UDim2.new(1,0,0,1),Position=UDim2.new(0,0,0.5,0),BackgroundColor3=C.bord},f); local bg=mk("Frame",{Size=UDim2.new(0,0,1,0),AutomaticSize=Enum.AutomaticSize.X,BackgroundColor3=C.bg,Position=UDim2.new(0,10,0,0)},f); mk("TextLabel",{BackgroundTransparency=1,Text=" "..s.." ",Size=UDim2.new(0,0,1,0),AutomaticSize=Enum.AutomaticSize.X,Font=Enum.Font.GothamBold,TextSize=10,TextColor3=C.sub,TextXAlignment=Enum.TextXAlignment.Left},bg) end

local function Toggle(t,text,def,cb)
    t.n+=1; local row=mk("Frame",{Size=UDim2.new(1,0,0,36),BackgroundColor3=C.bg2,LayoutOrder=t.n},t.scroll); cr(7,row)
    mk("TextLabel",{BackgroundTransparency=1,Text=text,Size=UDim2.new(1,-56,1,0),Position=UDim2.new(0,12,0,0),Font=Enum.Font.Gotham,TextSize=13,TextColor3=C.txt,TextXAlignment=Enum.TextXAlignment.Left},row)
    local tr=mk("Frame",{Size=UDim2.new(0,36,0,19),Position=UDim2.new(1,-46,0.5,-9),BackgroundColor3=def and C.on or C.off},row); cr(9,tr)
    local kn=mk("Frame",{Size=UDim2.new(0,13,0,13),Position=def and UDim2.new(1,-16,0.5,-6) or UDim2.new(0,3,0.5,-6),BackgroundColor3=Color3.new(1,1,1)},tr); cr(6,kn)
    local v=def or false
    local cl=mk("TextButton",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text="",AutoButtonColor=false},row)
    cl.MouseButton1Click:Connect(function() v=not v; tw(tr,.15,{BackgroundColor3=v and C.on or C.off}); tw(kn,.15,{Position=v and UDim2.new(1,-16,0.5,-6) or UDim2.new(0,3,0.5,-6)}); pcall(cb,v) end)
    cl.MouseEnter:Connect(function() tw(row,.08,{BackgroundColor3=C.bg3}) end)
    cl.MouseLeave:Connect(function() tw(row,.08,{BackgroundColor3=C.bg2}) end)
end

local function Slider(t,text,mn,mx,def,sfx,cb)
    t.n+=1; local row=mk("Frame",{Size=UDim2.new(1,0,0,52),BackgroundColor3=C.bg2,LayoutOrder=t.n},t.scroll); cr(7,row)
    mk("TextLabel",{BackgroundTransparency=1,Text=text,Size=UDim2.new(0.6,0,0,22),Position=UDim2.new(0,12,0,5),Font=Enum.Font.Gotham,TextSize=13,TextColor3=C.txt,TextXAlignment=Enum.TextXAlignment.Left},row)
    local vl=mk("TextLabel",{BackgroundTransparency=1,Text=def..(sfx or ""),Size=UDim2.new(0,80,0,22),Position=UDim2.new(1,-88,0,5),Font=Enum.Font.GothamBold,TextSize=12,TextColor3=C.acc2,TextXAlignment=Enum.TextXAlignment.Right},row)
    local track=mk("Frame",{Size=UDim2.new(1,-24,0,4),Position=UDim2.new(0,12,0,34),BackgroundColor3=C.bg3},row); cr(2,track)
    local pct=(def-mn)/(mx-mn)
    local fill=mk("Frame",{Size=UDim2.new(pct,0,1,0),BackgroundColor3=C.acc},track); cr(2,fill); Instance.new("UIGradient",fill).Color=ColorSequence.new(C.acc,C.acc2)
    local handle=mk("Frame",{Size=UDim2.new(0,11,0,11),Position=UDim2.new(pct,-5,0.5,-5),BackgroundColor3=Color3.new(1,1,1)},track); cr(5,handle)
    local d2=false
    local function upd(x) local r=math.clamp((x-track.AbsolutePosition.X)/track.AbsoluteSize.X,0,1); local val=math.floor(mn+(mx-mn)*r); fill.Size=UDim2.new(r,0,1,0); handle.Position=UDim2.new(r,-5,0.5,-5); vl.Text=val..(sfx or ""); pcall(cb,val) end
    track.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then d2=true; upd(i.Position.X) end end)
    UIS.InputChanged:Connect(function(i) if d2 and i.UserInputType==Enum.UserInputType.MouseMovement then upd(i.Position.X) end end)
    UIS.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then d2=false end end)
    row.MouseEnter:Connect(function() tw(row,.08,{BackgroundColor3=C.bg3}) end); row.MouseLeave:Connect(function() tw(row,.08,{BackgroundColor3=C.bg2}) end)
end

local function Dropdown(t,text,opts,def,cb)
    t.n+=1; local H=36
    local row=mk("Frame",{Size=UDim2.new(1,0,0,H),BackgroundColor3=C.bg2,ClipsDescendants=true,LayoutOrder=t.n},t.scroll); cr(7,row)
    mk("TextLabel",{BackgroundTransparency=1,Text=text,Size=UDim2.new(0.52,0,0,H),Position=UDim2.new(0,12,0,0),Font=Enum.Font.Gotham,TextSize=13,TextColor3=C.txt,TextXAlignment=Enum.TextXAlignment.Left},row)
    local sel=mk("TextLabel",{BackgroundTransparency=1,Text=def,Size=UDim2.new(0.38,0,0,H),Position=UDim2.new(0.55,0,0,0),Font=Enum.Font.GothamBold,TextSize=12,TextColor3=C.acc2,TextXAlignment=Enum.TextXAlignment.Right},row)
    local arr=mk("TextLabel",{BackgroundTransparency=1,Text="▾",Size=UDim2.new(0,20,0,H),Position=UDim2.new(1,-22,0,0),Font=Enum.Font.GothamBold,TextSize=14,TextColor3=C.sub},row)
    local btns={}; for i,opt in ipairs(opts) do
        local ob=mk("TextButton",{Size=UDim2.new(1,0,0,30),Position=UDim2.new(0,0,0,H+(i-1)*30),BackgroundColor3=C.bg3,Text=opt,TextColor3=opt==def and C.acc2 or C.sub,TextSize=12,Font=Enum.Font.Gotham,AutoButtonColor=false},row); btns[i]=ob
        ob.MouseButton1Click:Connect(function() sel.Text=opt; for _,b in ipairs(btns) do tw(b,.1,{TextColor3=C.sub}) end; tw(ob,.1,{TextColor3=C.acc2}); tw(row,.18,{Size=UDim2.new(1,0,0,H)}); tw(arr,.18,{Rotation=0}); pcall(cb,opt) end)
        ob.MouseEnter:Connect(function() tw(ob,.06,{BackgroundColor3=Color3.fromRGB(30,34,50)}) end); ob.MouseLeave:Connect(function() tw(ob,.06,{BackgroundColor3=C.bg3}) end)
    end
    local open=false
    mk("TextButton",{Size=UDim2.new(1,0,0,H),BackgroundTransparency=1,Text="",AutoButtonColor=false},row).MouseButton1Click:Connect(function() open=not open; tw(row,.18,{Size=UDim2.new(1,0,0,open and H+#opts*30 or H)}); tw(arr,.18,{Rotation=open and 180 or 0}) end)
    row.MouseEnter:Connect(function() tw(row,.08,{BackgroundColor3=C.bg3}) end); row.MouseLeave:Connect(function() tw(row,.08,{BackgroundColor3=C.bg2}) end)
end

local function Btn(t,text,cb) t.n+=1; local b=mk("TextButton",{Size=UDim2.new(1,0,0,36),BackgroundColor3=C.acc,Text=text,TextColor3=Color3.new(1,1,1),TextSize=13,Font=Enum.Font.GothamBold,AutoButtonColor=false,LayoutOrder=t.n},t.scroll); cr(7,b); b.MouseButton1Click:Connect(function() pcall(cb) end); b.MouseEnter:Connect(function() tw(b,.1,{BackgroundColor3=Color3.fromRGB(120,122,255)}) end); b.MouseLeave:Connect(function() tw(b,.1,{BackgroundColor3=C.acc}) end) end

local function Info(t,text,h) t.n+=1; local row=mk("Frame",{Size=UDim2.new(1,0,0,h or 36),BackgroundColor3=C.bg3,LayoutOrder=t.n},t.scroll); cr(7,row); stroke(row,C.bord,1); mk("TextLabel",{BackgroundTransparency=1,Text=text,Size=UDim2.new(1,-18,1,0),Position=UDim2.new(0,10,0,0),Font=Enum.Font.Gotham,TextSize=11,TextColor3=C.sub,TextWrapped=true,TextXAlignment=Enum.TextXAlignment.Left},row) end

