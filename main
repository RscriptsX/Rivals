-- Dragging for key card
local kDrag, kDS, kWS = false, nil, nil
keyCard.InputBegan:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 then
        kDrag = true; kDS = i.Position; kWS = keyCard.Position
    end
end)
UIS.InputChanged:Connect(function(i)
    if kDrag and i.UserInputType == Enum.UserInputType.MouseMovement then
        local d = i.Position - kDS
        keyCard.Position = UDim2.new(kWS.X.Scale, kWS.X.Offset + d.X, kWS.Y.Scale, kWS.Y.Offset + d.Y)
    end
end)
UIS.InputEnded:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 then kDrag = false end
end)

-- Key validation
local function tryKey()
    local input = keyInput.Text:gsub("%s", "")
    if input == VALID_KEY then
        keyOK = true
        keyStatus.TextColor3 = TH.green
        keyStatus.Text = "Key accepted — loading..."
        tw(keyBtn, 0.2, { BackgroundColor3 = TH.green })
        taskLib.wait(0.6)
        tw(keyCard, 0.3, { Position = UDim2.new(0.5, -200, 0.5, -200), BackgroundTransparency = 1 })
        tw(overlay, 0.3, { BackgroundTransparency = 1 })
        taskLib.wait(0.35)
        KGui:Destroy()
    else
        keyStatus.TextColor3 = TH.red
        keyStatus.Text = "Invalid key — try again"
        -- Shake animation
        local orig = keyCard.Position
        for i = 1, 3 do
            tw(keyCard, 0.04, { Position = UDim2.new(orig.X.Scale, orig.X.Offset + 8, orig.Y.Scale, orig.Y.Offset) })
            taskLib.wait(0.04)
            tw(keyCard, 0.04, { Position = UDim2.new(orig.X.Scale, orig.X.Offset - 8, orig.Y.Scale, orig.Y.Offset) })
            taskLib.wait(0.04)
        end
        tw(keyCard, 0.04, { Position = orig })
    end
end

keyBtn.MouseButton1Click:Connect(tryKey)
keyInput.FocusLost:Connect(function(enterPressed)
    if enterPressed then tryKey() end
end)

-- Wait for key
repeat taskLib.wait() until keyOK

