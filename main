-- ================================================================
--  UTILITY
-- ================================================================
local function sameTeam(p)
    return LP.Team~=nil and p.Team==LP.Team
end

local function isVisible(pos)
    local rp=RaycastParams.new()
    rp.FilterDescendantsInstances={LP.Character or Instance.new("Model")}
    rp.FilterType=Enum.RaycastFilterType.Exclude
    local res=workspace:Raycast(Camera.CFrame.Position,pos-Camera.CFrame.Position,rp)
    if not res then return true end
    return Players:GetPlayerFromCharacter(res.Instance.Parent)~=nil
end

local function getClosest(fov,part,teamCheck,visCheck,priority)
    local best,bestD,bestHP=nil,math.huge,math.huge
    local cx,cy=Camera.ViewportSize.X/2,Camera.ViewportSize.Y/2
    for _,p in ipairs(Players:GetPlayers()) do
        if p==LP then continue end
        if teamCheck and sameTeam(p) then continue end
        local ch=p.Character; local hm=ch and ch:FindFirstChildOfClass("Humanoid")
        local pt=ch and ch:FindFirstChild(part)
        if not(ch and hm and pt and hm.Health>0) then continue end
        if visCheck and not isVisible(pt.Position) then continue end
        local sp,on=Camera:WorldToViewportPoint(pt.Position)
        if not on then continue end
        local screenDist=math.sqrt((sp.X-cx)^2+(sp.Y-cy)^2)
        if fov and screenDist>fov then continue end
        local worldDist=(pt.Position-Camera.CFrame.Position).Magnitude
        local hp=hm.Health
        local score
        if priority=="Lowest HP" then score=hp
        elseif priority=="Nearest" then score=worldDist
        else score=screenDist end -- Closest to crosshair
        if score<bestD then bestD=score; best=p end
    end
    return best
end

-- ================================================================
--  WALLBANG
-- ================================================================
local wbParts={}; local wbConn=nil

local function isCharPart(v)
    for _,p in ipairs(Players:GetPlayers()) do
        if p.Character and v:IsDescendantOf(p.Character) then return true end
    end
    return false
end

function enableWB()
    for _,v in ipairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") and not isCharPart(v) then
            pcall(function() if v.CanQuery then wbParts[v]=true; v.CanQuery=false end end)
        end
    end
    wbConn=workspace.DescendantAdded:Connect(function(v)
        task.wait()
        if v:IsA("BasePart") and not isCharPart(v) then
            pcall(function() v.CanQuery=false; wbParts[v]=true end)
        end
    end)
end

function disableWB()
    if wbConn then wbConn:Disconnect(); wbConn=nil end
    for v in pairs(wbParts) do pcall(function() if v and v.Parent then v.CanQuery=true end end) end
    wbParts={}
end

-- ================================================================
--  FLY
-- ================================================================
local flyBV,flyBG=nil,nil
function enableFly()
    local ch=LP.Character; local root=ch and ch:FindFirstChild("HumanoidRootPart"); if not root then return end
    local hm=ch:FindFirstChildOfClass("Humanoid"); if hm then hm.PlatformStand=true end
    flyBV=Instance.new("BodyVelocity",root); flyBV.Velocity=Vector3.zero; flyBV.MaxForce=Vector3.new(1e9,1e9,1e9)
    flyBG=Instance.new("BodyGyro",root); flyBG.MaxTorque=Vector3.new(1e9,1e9,1e9); flyBG.P=1e4; flyBG.CFrame=root.CFrame
end
function disableFly()
    if flyBV then flyBV:Destroy(); flyBV=nil end; if flyBG then flyBG:Destroy(); flyBG=nil end
    local ch=LP.Character; local hm=ch and ch:FindFirstChildOfClass("Humanoid"); if hm then hm.PlatformStand=false end
end

-- ================================================================
--  ESP ENGINE
-- ================================================================
local pool={}

local function makeESP(player)
    if player==LP then return end
    local D=Drawing.new
    local e={}
    e.box=D("Square"); e.box.Filled=false; e.box.Thickness=1.5
    e.fill=D("Square"); e.fill.Filled=true; e.fill.Transparency=0.85
    e.corners={}; for i=1,8 do local l=D("Line"); l.Thickness=1.8; l.Visible=false; e.corners[i]=l end
    e.name=D("Text"); e.name.Center=true; e.name.Outline=true; e.name.Size=13; e.name.Font=Drawing.Fonts.UI
    e.dist=D("Text"); e.dist.Center=true; e.dist.Outline=true; e.dist.Size=11; e.dist.Font=Drawing.Fonts.UI; e.dist.Color=Color3.fromRGB(170,180,200)
    e.hbg=D("Square"); e.hbg.Filled=true; e.hbg.Color=Color3.fromRGB(15,15,15)
    e.hfill=D("Square"); e.hfill.Filled=true
    e.tracer=D("Line"); e.tracer.Thickness=1
    e.hdot=D("Circle"); e.hdot.Filled=true; e.hdot.Radius=4
    e.sdot=D("Circle"); e.sdot.Filled=true; e.sdot.Radius=5; e.sdot.Color=Color3.fromRGB(0,255,180)
    for k,d in pairs(e) do if k~="corners" then d.Visible=false end end
    pool[player]=e
end

local function killESP(p)
    if pool[p] then
        for k,d in pairs(pool[p]) do if k=="corners" then for _,l in ipairs(d) do l:Remove() end else d:Remove() end end
        pool[p]=nil
    end
end

local silentTarget=nil

local function drawCorner(e,x,y,w,h,col)
    local cw,ch2=w*.25,h*.25
    local pts={{x,y,x+cw,y,x,y,x,y+ch2},{x+w,y,x+w-cw,y,x+w,y,x+w,y+ch2},{x,y+h,x+cw,y+h,x,y+h,x,y+h-ch2},{x+w,y+h,x+w-cw,y+h,x+w,y+h,x+w,y+h-ch2}}
    local i=1; for _,c in ipairs(pts) do
        e.corners[i].From=Vector2.new(c[1],c[2]); e.corners[i].To=Vector2.new(c[3],c[4]); e.corners[i].Color=col; e.corners[i].Visible=true; i+=1
        e.corners[i].From=Vector2.new(c[5],c[6]); e.corners[i].To=Vector2.new(c[7],c[8]); e.corners[i].Color=col; e.corners[i].Visible=true; i+=1
    end
end

local function updateESP()
    for player,e in pairs(pool) do
        local ch=player.Character; local hm=ch and ch:FindFirstChildOfClass("Humanoid")
        local root=ch and ch:FindFirstChild("HumanoidRootPart"); local head=ch and ch:FindFirstChild("Head")
        local d3=root and (root.Position-Camera.CFrame.Position).Magnitude or 9999
        local show=CFG.ESP.On and ch and hm and root and head and hm.Health>0 and d3<=CFG.ESP.MaxDist and not(CFG.ESP.Team and sameTeam(player))
        for k,d in pairs(e) do if k~="corners" then d.Visible=false end end; for _,l in ipairs(e.corners) do l.Visible=false end
        if show then
            local rp,on=Camera:WorldToViewportPoint(root.Position); local hp2=Camera:WorldToViewportPoint(head.Position)
            if on then
                local sc=1/rp.Z*375; local w,h2=sc*1.1,sc*2.7; local x,y=rp.X-w/2,hp2.Y-3; local col=Color3.fromRGB(255,60,60)
                if CFG.ESP.Style=="Corner" then drawCorner(e,x,y,w,h2,col)
                else e.box.Position=Vector2.new(x,y); e.box.Size=Vector2.new(w,h2); e.box.Color=col; e.box.Visible=CFG.ESP.Boxes
                     e.fill.Position=Vector2.new(x,y); e.fill.Size=Vector2.new(w,h2); e.fill.Color=col; e.fill.Visible=CFG.ESP.Boxes and CFG.ESP.Fill end
                e.name.Position=Vector2.new(rp.X,y-16); e.name.Text=player.DisplayName; e.name.Color=Color3.new(1,1,1); e.name.Visible=CFG.ESP.Names
                e.dist.Position=Vector2.new(rp.X,y+h2+3); e.dist.Text=math.floor(d3).."m"; e.dist.Visible=CFG.ESP.Dist
                e.tracer.From=Vector2.new(Camera.ViewportSize.X/2,Camera.ViewportSize.Y); e.tracer.To=Vector2.new(rp.X,y+h2); e.tracer.Color=Color3.fromRGB(0,210,255); e.tracer.Visible=CFG.ESP.Tracers
                local php=hm.Health/hm.MaxHealth
                e.hbg.Position=Vector2.new(x-7,y); e.hbg.Size=Vector2.new(4,h2); e.hbg.Visible=CFG.ESP.Health
                e.hfill.Position=Vector2.new(x-7,y+h2*(1-php)); e.hfill.Size=Vector2.new(4,h2*php); e.hfill.Color=Color3.fromRGB(math.floor(255*(1-php)),math.floor(255*php),0); e.hfill.Visible=CFG.ESP.Health
                local hsp=Camera:WorldToViewportPoint(head.Position); e.hdot.Position=Vector2.new(hsp.X,hsp.Y); e.hdot.Color=col; e.hdot.Visible=CFG.ESP.HeadDot
                if CFG.SA.On and CFG.SA.Dot and silentTarget==player then
                    local tp=ch:FindFirstChild(CFG.SA.Part); if tp then local sp2=Camera:WorldToViewportPoint(tp.Position); e.sdot.Position=Vector2.new(sp2.X,sp2.Y); e.sdot.Visible=true end
                end
            end
        end
    end
end

for _,p in ipairs(Players:GetPlayers()) do makeESP(p) end
Players.PlayerAdded:Connect(function(p) makeESP(p); p.CharacterAdded:Connect(function() task.wait(0.5); if not pool[p] then makeESP(p) end end) end)
Players.PlayerRemoving:Connect(killESP)
for _,p in ipairs(Players:GetPlayers()) do p.CharacterAdded:Connect(function() task.wait(0.5); if not pool[p] then makeESP(p) end end) end

-- Chams on new characters
Players.PlayerAdded:Connect(function(p) p.CharacterAdded:Connect(function(ch)
    if CFG.ESP.Chams and p~=LP then
        task.wait(0.5); local h=Instance.new("Highlight",ch); h.FillColor=Color3.fromRGB(255,30,30); h.OutlineColor=Color3.new(1,1,1); h.FillTransparency=0.5
    end
end) end)

-- ================================================================
--  AIMBOT (mousemoverel)
-- ================================================================
local fovCircle=Drawing.new("Circle"); fovCircle.Visible=false; fovCircle.Filled=false; fovCircle.Thickness=1.5; fovCircle.NumSides=64; fovCircle.Color=Color3.fromRGB(180,185,255)

local aimKeyCheck={
    RMB=function() return UIS:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) end,
    LMB=function() return UIS:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) end,
    Q=function() return UIS:IsKeyDown(Enum.KeyCode.Q) end, E=function() return UIS:IsKeyDown(Enum.KeyCode.E) end,
    Z=function() return UIS:IsKeyDown(Enum.KeyCode.Z) end, X=function() return UIS:IsKeyDown(Enum.KeyCode.X) end,
    C=function() return UIS:IsKeyDown(Enum.KeyCode.C) end, V=function() return UIS:IsKeyDown(Enum.KeyCode.V) end,
}

local function isAimHeld() local fn=aimKeyCheck[CFG.Aim.Key]; return fn and fn() or false end

local function doAim(targetPos, instant)
    local sp,on=Camera:WorldToViewportPoint(targetPos)
    if not on then return end
    local dx=sp.X-Camera.ViewportSize.X/2; local dy=sp.Y-Camera.ViewportSize.Y/2
    if instant then
        if _mmr then pcall(_mmr,dx,dy) else Camera.CFrame=CFrame.new(Camera.CFrame.Position,targetPos) end
    else
        local s=CFG.Aim.Smooth/100
        if _mmr then pcall(_mmr,dx*s,dy*s) else Camera.CFrame=Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position,targetPos),s) end
    end
end

-- ================================================================
--  SILENT AIM (dual hook: __namecall + hookfunction fallback)
-- ================================================================
local saHooked = false

-- Deep scan and replace all hit data in args (handles nested tables)
local function deepReplace(args, targetPart)
    for i, v in ipairs(args) do
        if typeof(v)=="Vector3" then
            args[i]=targetPart.Position
        elseif typeof(v)=="CFrame" then
            args[i]=CFrame.new(targetPart.Position)
        elseif typeof(v)=="Instance" then
            if v:IsA("BasePart") then
                local owner=Players:GetPlayerFromCharacter(v.Parent) or Players:GetPlayerFromCharacter(v)
                if owner and owner~=LP then args[i]=targetPart end
            elseif v:IsA("Model") then
                local owner=Players:GetPlayerFromCharacter(v)
                if owner and owner~=LP then args[i]=targetPart.Parent end
            end
        elseif type(v)=="table" then
            -- RECURSIVE: scan inside tables (Rivals passes hit data in tables)
            for k2, v2 in pairs(v) do
                if typeof(v2)=="Vector3" then v[k2]=targetPart.Position
                elseif typeof(v2)=="CFrame" then v[k2]=CFrame.new(targetPart.Position)
                elseif typeof(v2)=="Instance" and v2:IsA("BasePart") then
                    local owner=Players:GetPlayerFromCharacter(v2.Parent) or Players:GetPlayerFromCharacter(v2)
                    if owner and owner~=LP then v[k2]=targetPart end
                elseif typeof(v2)=="Instance" and v2:IsA("Model") then
                    local owner=Players:GetPlayerFromCharacter(v2)
                    if owner and owner~=LP then v[k2]=targetPart.Parent end
                elseif type(v2)=="table" then
                    -- Go one more level deep
                    for k3, v3 in pairs(v2) do
                        if typeof(v3)=="Vector3" then v2[k3]=targetPart.Position
                        elseif typeof(v3)=="CFrame" then v2[k3]=CFrame.new(targetPart.Position)
                        elseif typeof(v3)=="Instance" and v3:IsA("BasePart") then
                            local owner=Players:GetPlayerFromCharacter(v3.Parent) or Players:GetPlayerFromCharacter(v3)
                            if owner and owner~=LP then v2[k3]=targetPart end
                        end
                    end
                end
            end
        end
    end
    return args
end

local function doSilentAim(self, args)
    if not CFG.SA.On then return nil end
    if math.random(1,100) > CFG.SA.HitChance then return nil end
    local t = getClosest(
        CFG.SA.FOVCheck and CFG.SA.FOV or nil,
        CFG.SA.Part, CFG.SA.Team,
        false, -- no vis check for silent (shoot through walls)
        CFG.Rage.On and CFG.Rage.Priority or "Closest"
    )
    if not t then silentTarget=nil; return nil end
    silentTarget=t
    local ch=t.Character; local pt=ch and ch:FindFirstChild(CFG.SA.Part)
    if not pt then return nil end
    deepReplace(args, pt)
    return args
end

-- Method 1: __namecall
if _grm and _sro and _ncc and _gnm then
    pcall(function()
        local mt=_grm(game)
        local old=mt.__namecall
        _sro(mt,false)
        mt.__namecall=_ncc(function(self,...)
            local method=_gnm()
            if (method=="FireServer" or method=="InvokeServer") and (CFG.SA.On or CFG.Rage.On) then
                local args={...}
                local replaced=doSilentAim(self,args)
                if replaced then return old(self,table.unpack(replaced)) end
            end
            return old(self,...)
        end)
        _sro(mt,true)
        saHooked=true
    end)
end

-- Method 2: hookfunction on FireServer (fallback)
if not saHooked and _hkf and _ncc then
    pcall(function()
        local oldFS; oldFS=_hkf(Instance.new("RemoteEvent").FireServer,_ncc(function(self,...)
            if (CFG.SA.On or CFG.Rage.On) then
                local args={...}
                local replaced=doSilentAim(self,args)
                if replaced then return oldFS(self,table.unpack(replaced)) end
            end
            return oldFS(self,...)
        end))
        saHooked=true
    end)
end

-- ================================================================
--  ONE-TIME CONNECTIONS (not in RenderStepped!)
-- ================================================================
UIS.JumpRequest:Connect(function()
    if CFG.Misc.InfJump then
        local c=LP.Character; local h=c and c:FindFirstChildOfClass("Humanoid")
        if h then h:ChangeState(Enum.HumanoidStateType.Jumping) end
    end
end)

LP.Idled:Connect(function()
    if CFG.Misc.AntiAFK then
        pcall(function()
            local vu=game:GetService("VirtualUser")
            vu:Button2Down(Vector2.new(0,0),Camera.CFrame); task.wait(0.1)
            vu:Button2Up(Vector2.new(0,0),Camera.CFrame)
        end)
    end
end)

-- ================================================================
--  MAIN LOOP
-- ================================================================
RunService.RenderStepped:Connect(function()
    local cv=Camera.ViewportSize
    fovCircle.Position=Vector2.new(cv.X/2,cv.Y/2); fovCircle.Radius=CFG.Aim.FOV
    fovCircle.Visible=CFG.Aim.Circle and (CFG.Aim.On or CFG.Rage.On)

    updateESP()

    -- ── RAGEBOT (overrides aimbot)
    if CFG.Rage.On then
        local t=getClosest(nil,"Head",CFG.Aim.Team,false,CFG.Rage.Priority)
        if t then
            local ch=t.Character; local pt=ch and ch:FindFirstChild("Head")
            if pt then
                local root=ch:FindFirstChild("HumanoidRootPart")
                local pred=pt.Position+(root and root.Velocity*(CFG.Aim.Pred/100) or Vector3.zero)
                -- Instant snap
                doAim(pred,true)
                -- Auto-fire
                if CFG.Rage.AutoFire then
                    if _m1c then pcall(_m1c) elseif _m1p and _m1r then pcall(_m1p); task.defer(function() pcall(_m1r) end) end
                end
            end
        end
        -- Anti-aim (desync character rotation)
        if CFG.Rage.AntiAim then
            local root=LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
            if root then
                pcall(function()
                    root.CFrame=CFrame.new(root.Position) * CFrame.Angles(0,math.rad(tick()*2000%360),0)
                end)
            end
        end

    -- ── REGULAR AIMBOT
    elseif CFG.Aim.On and isAimHeld() then
        local t=getClosest(CFG.Aim.FOV,CFG.Aim.Part,CFG.Aim.Team,CFG.Aim.VisCheck,"Closest")
        if t then
            local ch=t.Character; local pt=ch and ch:FindFirstChild(CFG.Aim.Part)
            if pt then
                local root=ch:FindFirstChild("HumanoidRootPart")
                local pred=pt.Position+(root and root.Velocity*(CFG.Aim.Pred/100) or Vector3.zero)
                doAim(pred,false)
            end
        end
    end

    -- ── Fly
    if CFG.Misc.Fly and flyBV and flyBG then
        local root=LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
        if root then
            local vel=Vector3.zero; local spd=CFG.Misc.FlySpeed
            if UIS:IsKeyDown(Enum.KeyCode.W) then vel+=Camera.CFrame.LookVector*spd end
            if UIS:IsKeyDown(Enum.KeyCode.S) then vel-=Camera.CFrame.LookVector*spd end
            if UIS:IsKeyDown(Enum.KeyCode.A) then vel-=Camera.CFrame.RightVector*spd end
            if UIS:IsKeyDown(Enum.KeyCode.D) then vel+=Camera.CFrame.RightVector*spd end
            if UIS:IsKeyDown(Enum.KeyCode.Space) then vel+=Vector3.new(0,spd,0) end
            if UIS:IsKeyDown(Enum.KeyCode.LeftShift) then vel-=Vector3.new(0,spd,0) end
            flyBV.Velocity=vel; flyBG.CFrame=Camera.CFrame
        end
    end

    -- ── Noclip
    if CFG.Misc.Noclip then
        local ch=LP.Character; if ch then for _,p in ipairs(ch:GetDescendants()) do if p:IsA("BasePart") then p.CanCollide=false end end end
    end
end)

-- ── Startup notifications
task.delay(0.5, function()
    Notify("RscriptsX","Loaded — key authenticated",3,C.on)
    task.wait(0.3)
    Notify("Aimbot", _mmr and "mousemoverel ✓ ready" or "⚠ mousemoverel missing — using camera fallback",4,_mmr and C.on or C.orange)
    task.wait(0.3)
    Notify("Silent Aim", saHooked and "Hook installed ✓ (shoots anywhere → hits target)" or "⚠ Hook failed — executor unsupported",4,saHooked and C.on or C.red)
end)
