Slider(tMisc, "Walk Speed", 16, 250, 16, " WS", function(v)
    CFG.Misc.Speed = v
    local ch = LP.Character
    local hm = ch and ch:FindFirstChildOfClass("Humanoid")
    if hm then hm.WalkSpeed = v end
end)
