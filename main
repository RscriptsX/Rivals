-- Check drawing support
local drawingSupported = pcall(function() 
    local d = Drawing.new("Text")
    d:Remove()
end)

if not drawingSupported then
    warn("Drawing library not supported – ESP and FOV circles will be disabled")
end

local function wrapCC(fn)
    if EXEC.ncc then return EXEC.ncc(fn) end
    return fn
end

