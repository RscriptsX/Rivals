-- ========== TAB SYSTEM ==========
local tabs = {}
local activeTab = nil

local function createTab(label, icon, order)
    local btn = mk("TextButton", {
        Size = UDim2.new(1, -8, 0, 34),
        BackgroundColor3 = TH.sidebar,
        BackgroundTransparency = 0,
        Text = "",
        AutoButtonColor = false,
        LayoutOrder = order,
    }, SidebarFrame)
    cr(8, btn)

    local indicator = mk("Frame", {
        Size = UDim2.new(0, 3, 0, 0),
        Position = UDim2.new(0, 4, 0.5, 0),
        BackgroundColor3 = TH.accent2,
        AnchorPoint = Vector2.new(0, 0.5),
    }, btn)
    cr(2, indicator)

    local iconLabel = mk("TextLabel", {
        BackgroundTransparency = 1,
        Text = icon or "",
        Size = UDim2.new(0, 24, 1, 0),
        Position = UDim2.new(0, 14, 0, 0),
        Font = Enum.Font.GothamBold,
        TextSize = 12,
        TextColor3 = TH.subtext,
        TextXAlignment = Enum.TextXAlignment.Center,
    }, btn)

    local labelText = mk("TextLabel", {
        BackgroundTransparency = 1,
        Text = label,
        Size = UDim2.new(1, -44, 1, 0),
        Position = UDim2.new(0, 40, 0, 0),
        Font = Enum.Font.GothamBold,
        TextSize = 12,
        TextColor3 = TH.subtext,
        TextXAlignment = Enum.TextXAlignment.Left,
    }, btn)

    local scroll = Instance.new("ScrollingFrame", ContentFrame)
    scroll.Size = UDim2.new(1, 0, 1, 0)
    scroll.BackgroundTransparency = 1
    scroll.BorderSizePixel = 0
    scroll.ScrollBarThickness = 3
    scroll.ScrollBarImageColor3 = TH.accent
    scroll.CanvasSize = UDim2.new(0, 0, 0, 0)
    scroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
    scroll.Visible = false
    scroll.ScrollingDirection = Enum.ScrollingDirection.Y

    local layout = Instance.new("UIListLayout", scroll)
    layout.Padding = UDim.new(0, 5)
    layout.SortOrder = Enum.SortOrder.LayoutOrder

    local padding = Instance.new("UIPadding", scroll)
    padding.PaddingTop = UDim.new(0, 8)
    padding.PaddingBottom = UDim.new(0, 12)
    padding.PaddingLeft = UDim.new(0, 10)
    padding.PaddingRight = UDim.new(0, 10)

    local tab = {
        btn = btn,
        indicator = indicator,
        iconLabel = iconLabel,
        labelText = labelText,
        scroll = scroll,
        n = 0,
    }
    tabs[label] = tab

    btn.MouseButton1Click:Connect(function()
        if activeTab then
            activeTab.scroll.Visible = false
            tw(activeTab.btn, 0.15, { BackgroundColor3 = TH.sidebar })
            tw(activeTab.indicator, 0.15, { Size = UDim2.new(0, 3, 0, 0) })
            tw(activeTab.iconLabel, 0.15, { TextColor3 = TH.subtext })
            tw(activeTab.labelText, 0.15, { TextColor3 = TH.subtext })
        end
        activeTab = tab
        tab.scroll.Visible = true
        tw(btn, 0.15, { BackgroundColor3 = TH.sideAct })
        tw(indicator, 0.15, { Size = UDim2.new(0, 3, 0, 18) })
        tw(iconLabel, 0.15, { TextColor3 = TH.accent2 })
        tw(labelText, 0.15, { TextColor3 = TH.text })
    end)

    btn.MouseEnter:Connect(function()
        if activeTab ~= tab then
            tw(btn, 0.08, { BackgroundColor3 = TH.sideHov })
        end
    end)
    btn.MouseLeave:Connect(function()
        if activeTab ~= tab then
            tw(btn, 0.08, { BackgroundColor3 = TH.sidebar })
        end
    end)

    return tab
end

-- ========== GUI COMPONENTS ==========
local function Section(tab, text)
    tab.n += 1
    local container = mk("Frame", {
        Size = UDim2.new(1, 0, 0, 26),
        BackgroundTransparency = 1,
        LayoutOrder = tab.n,
    }, tab.scroll)

    mk("Frame", {
        Size = UDim2.new(1, 0, 0, 1),
        Position = UDim2.new(0, 0, 0.5, 0),
        BackgroundColor3 = TH.border,
    }, container)

    local labelBG = mk("Frame", {
        Size = UDim2.new(0, 0, 1, 0),
        AutomaticSize = Enum.AutomaticSize.X,
        BackgroundColor3 = TH.bg,
        Position = UDim2.new(0, 4, 0, 0),
    }, container)

    mk("TextLabel", {
        BackgroundTransparency = 1,
        Text = "  " .. text .. "  ",
        Size = UDim2.new(0, 0, 1, 0),
        AutomaticSize = Enum.AutomaticSize.X,
        Font = Enum.Font.GothamBold,
        TextSize = 10,
        TextColor3 = TH.subtext,
        TextXAlignment = Enum.TextXAlignment.Left,
    }, labelBG)
end

local function Toggle(tab, text, default, callback)
    tab.n += 1
    local row = mk("Frame", {
        Size = UDim2.new(1, 0, 0, 38),
        BackgroundColor3 = TH.bg2,
        LayoutOrder = tab.n,
    }, tab.scroll)
    cr(8, row)

    mk("TextLabel", {
        BackgroundTransparency = 1,
        Text = text,
        Size = UDim2.new(1, -60, 1, 0),
        Position = UDim2.new(0, 14, 0, 0),
        Font = Enum.Font.Gotham,
        TextSize = 13,
        TextColor3 = TH.text,
        TextXAlignment = Enum.TextXAlignment.Left,
    }, row)

    local track = mk("Frame", {
        Size = UDim2.new(0, 40, 0, 21),
        Position = UDim2.new(1, -52, 0.5, -10),
        BackgroundColor3 = default and TH.green or TH.offWhite,
    }, row)
    cr(10, track)

    local knob = mk("Frame", {
        Size = UDim2.new(0, 15, 0, 15),
        Position = default and UDim2.new(1, -18, 0.5, -7) or UDim2.new(0, 3, 0.5, -7),
        BackgroundColor3 = Color3.new(1, 1, 1),
    }, track)
    cr(7, knob)

    local knobStroke = addStroke(knob, Color3.fromRGB(0, 0, 0), 0.5)
    knobStroke.Transparency = 0.8

    local value = default or false

    local clickArea = mk("TextButton", {
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        Text = "",
        AutoButtonColor = false,
    }, row)

    clickArea.MouseButton1Click:Connect(function()
        value = not value
        tw(track, 0.18, { BackgroundColor3 = value and TH.green or TH.offWhite })
        tw(knob, 0.18, { Position = value and UDim2.new(1, -18, 0.5, -7) or UDim2.new(0, 3, 0.5, -7) })
        pcall(callback, value)
    end)

    clickArea.MouseEnter:Connect(function() tw(row, 0.08, { BackgroundColor3 = TH.bg3 }) end)
    clickArea.MouseLeave:Connect(function() tw(row, 0.08, { BackgroundColor3 = TH.bg2 }) end)
end

local function Slider(tab, text, min, max, default, suffix, callback)
    tab.n += 1
    local row = mk("Frame", {
        Size = UDim2.new(1, 0, 0, 56),
        BackgroundColor3 = TH.bg2,
        LayoutOrder = tab.n,
    }, tab.scroll)
    cr(8, row)

    mk("TextLabel", {
        BackgroundTransparency = 1,
        Text = text,
        Size = UDim2.new(0.6, 0, 0, 24),
        Position = UDim2.new(0, 14, 0, 5),
        Font = Enum.Font.Gotham,
        TextSize = 13,
        TextColor3 = TH.text,
        TextXAlignment = Enum.TextXAlignment.Left,
    }, row)

    local valLabel = mk("TextLabel", {
        BackgroundTransparency = 1,
        Text = tostring(default) .. (suffix or ""),
        Size = UDim2.new(0.35, 0, 0, 24),
        Position = UDim2.new(1, -14, 0, 5),
        Font = Enum.Font.GothamBold,
        TextSize = 12,
        TextColor3 = TH.accent2,
        TextXAlignment = Enum.TextXAlignment.Right,
    }, row)

    local track = mk("Frame", {
        Size = UDim2.new(1, -28, 0, 6),
        Position = UDim2.new(0, 14, 0, 38),
        BackgroundColor3 = TH.bg4,
    }, row)
    cr(3, track)

    local pct = (default - min) / (max - min)
    local fill = mk("Frame", {
        Size = UDim2.new(pct, 0, 1, 0),
        BackgroundColor3 = TH.accent,
    }, track)
    cr(3, fill)
    addGradient(fill, TH.accent, TH.accent2)

    local handle = mk("Frame", {
        Size = UDim2.new(0, 14, 0, 14),
        Position = UDim2.new(pct, -7, 0.5, -7),
        BackgroundColor3 = Color3.new(1, 1, 1),
    }, track)
    cr(7, handle)
    local handleStroke = addStroke(handle, Color3.fromRGB(0, 0, 0), 0.5)
    handleStroke.Transparency = 0.85

    local sliderDrag = false
    local currentVal = default

    local function update(inputX)
        local rel = math.clamp((inputX - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
        currentVal = math.floor(min + (max - min) * rel)
        fill.Size = UDim2.new(rel, 0, 1, 0)
        handle.Position = UDim2.new(rel, -7, 0.5, -7)
        valLabel.Text = tostring(currentVal) .. (suffix or "")
        pcall(callback, currentVal)
    end

    track.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            sliderDrag = true
            update(i.Position.X)
        end
    end)
    handle.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            sliderDrag = true
        end
    end)
    UIS.InputChanged:Connect(function(i)
        if sliderDrag and i.UserInputType == Enum.UserInputType.MouseMovement then
            update(i.Position.X)
        end
    end)
    UIS.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            sliderDrag = false
        end
    end)

    row.MouseEnter:Connect(function() tw(row, 0.08, { BackgroundColor3 = TH.bg3 }) end)
    row.MouseLeave:Connect(function() tw(row, 0.08, { BackgroundColor3 = TH.bg2 }) end)
end

local function Dropdown(tab, text, options, default, callback)
    tab.n += 1
    local ROW_H = 38
    local OPT_H = 32

    local row = mk("Frame", {
        Size = UDim2.new(1, 0, 0, ROW_H),
        BackgroundColor3 = TH.bg2,
        ClipsDescendants = true,
        LayoutOrder = tab.n,
    }, tab.scroll)
    cr(8, row)

    mk("TextLabel", {
        BackgroundTransparency = 1,
        Text = text,
        Size = UDim2.new(0.5, 0, 0, ROW_H),
        Position = UDim2.new(0, 14, 0, 0),
        Font = Enum.Font.Gotham,
        TextSize = 13,
        TextColor3 = TH.text,
        TextXAlignment = Enum.TextXAlignment.Left,
    }, row)

    local selLabel = mk("TextLabel", {
        BackgroundTransparency = 1,
        Text = default,
        Size = UDim2.new(0.4, -8, 0, ROW_H),
        Position = UDim2.new(0.55, 0, 0, 0),
        Font = Enum.Font.GothamBold,
        TextSize = 12,
        TextColor3 = TH.accent2,
        TextXAlignment = Enum.TextXAlignment.Right,
    }, row)

    local arrow = mk("TextLabel", {
        BackgroundTransparency = 1,
        Text = "v",
        Size = UDim2.new(0, 20, 0, ROW_H),
        Position = UDim2.new(1, -20, 0, 0),
        Font = Enum.Font.GothamBold,
        TextSize = 11,
        TextColor3 = TH.subtext,
    }, row)

    local optBtns = {}
    for i, opt in ipairs(options) do
        local optBtn = mk("TextButton", {
            Size = UDim2.new(1, -8, 0, OPT_H),
            Position = UDim2.new(0, 4, 0, ROW_H + (i - 1) * OPT_H),
            BackgroundColor3 = TH.bg3,
            Text = opt,
            TextColor3 = (opt == default) and TH.accent2 or TH.subtext,
            TextSize = 12,
            Font = Enum.Font.Gotham,
            AutoButtonColor = false,
        }, row)
        cr(6, optBtn)
        optBtns[i] = optBtn

        optBtn.MouseButton1Click:Connect(function()
            selLabel.Text = opt
            for _, b in ipairs(optBtns) do
                tw(b, 0.1, { TextColor3 = TH.subtext })
            end
            tw(optBtn, 0.1, { TextColor3 = TH.accent2 })
            tw(row, 0.2, { Size = UDim2.new(1, 0, 0, ROW_H) })
            tw(arrow, 0.2, { Rotation = 0 })
            pcall(callback, opt)
        end)

        optBtn.MouseEnter:Connect(function() tw(optBtn, 0.06, { BackgroundColor3 = TH.bg4 }) end)
        optBtn.MouseLeave:Connect(function() tw(optBtn, 0.06, { BackgroundColor3 = TH.bg3 }) end)
    end

    local isOpen = false
    local headerClick = mk("TextButton", {
        Size = UDim2.new(1, 0, 0, ROW_H),
        BackgroundTransparency = 1,
        Text = "",
        AutoButtonColor = false,
    }, row)

    headerClick.MouseButton1Click:Connect(function()
        isOpen = not isOpen
        local targetH = isOpen and (ROW_H + #options * OPT_H + 4) or ROW_H
        tw(row, 0.2, { Size = UDim2.new(1, 0, 0, targetH) })
        tw(arrow, 0.2, { Rotation = isOpen and 180 or 0 })
    end)

    row.MouseEnter:Connect(function() tw(row, 0.08, { BackgroundColor3 = TH.bg3 }) end)
    row.MouseLeave:Connect(function() tw(row, 0.08, { BackgroundColor3 = TH.bg2 }) end)
end

local function Button(tab, text, color, callback)
    tab.n += 1
    local btn = mk("TextButton", {
        Size = UDim2.new(1, 0, 0, 38),
        BackgroundColor3 = color or TH.accent,
        Text = text,
        TextColor3 = Color3.new(1, 1, 1),
        TextSize = 13,
        Font = Enum.Font.GothamBold,
        AutoButtonColor = false,
        LayoutOrder = tab.n,
    }, tab.scroll)
    cr(8, btn)

    btn.MouseButton1Click:Connect(function() pcall(callback) end)
    btn.MouseEnter:Connect(function()
        tw(btn, 0.1, { BackgroundTransparency = 0.15 })
    end)
    btn.MouseLeave:Connect(function()
        tw(btn, 0.1, { BackgroundTransparency = 0 })
    end)
end

local function InfoBox(tab, text, height)
    tab.n += 1
    local row = mk("Frame", {
        Size = UDim2.new(1, 0, 0, height or 40),
        BackgroundColor3 = TH.bg3,
        LayoutOrder = tab.n,
    }, tab.scroll)
    cr(8, row)
    addStroke(row, TH.border, 1)

    local accent = mk("Frame", {
        Size = UDim2.new(0, 3, 1, -8),
        Position = UDim2.new(0, 4, 0, 4),
        BackgroundColor3 = TH.accent2,
    }, row)
    cr(2, accent)

    mk("TextLabel", {
        BackgroundTransparency = 1,
        Text = text,
        Size = UDim2.new(1, -22, 1, 0),
        Position = UDim2.new(0, 14, 0, 0),
        Font = Enum.Font.Gotham,
        TextSize = 11,
        TextColor3 = TH.subtext,
        TextWrapped = true,
        TextXAlignment = Enum.TextXAlignment.Left,
    }, row)
end

local function StatusRow(tab, label, ok)
    tab.n += 1
    local row = mk("Frame", {
        Size = UDim2.new(1, 0, 0, 30),
        BackgroundColor3 = TH.bg2,
        LayoutOrder = tab.n,
    }, tab.scroll)
    cr(6, row)

    mk("Frame", {
        Size = UDim2.new(0, 8, 0, 8),
        Position = UDim2.new(0, 12, 0.5, -4),
        BackgroundColor3 = ok and TH.green or TH.red,
    }, row)

    mk("TextLabel", {
        BackgroundTransparency = 1,
        Text = label,
        Size = UDim2.new(1, -30, 1, 0),
        Position = UDim2.new(0, 28, 0, 0),
        Font = Enum.Font.Gotham,
        TextSize = 11,
        TextColor3 = ok and TH.text or TH.subtext,
        TextXAlignment = Enum.TextXAlignment.Left,
    }, row)
end

-- ========== NOTIFICATION SYSTEM ==========
local notifCount = 0

local function Notify(title, text, duration, color)
    notifCount += 1
    local idx = notifCount

    local n = mk("Frame", {
        Size = UDim2.new(0, 280, 0, 60),
        Position = UDim2.new(1, 10, 1, -(idx * 68)),
        BackgroundColor3 = TH.bg2,
    }, GUI)
    cr(10, n)
    addStroke(n, TH.border, 1)

    local bar = mk("Frame", {
        Size = UDim2.new(0, 3, 1, -10),
        Position = UDim2.new(0, 5, 0, 5),
        BackgroundColor3 = color or TH.accent2,
    }, n)
    cr(2, bar)

    mk("TextLabel", {
        BackgroundTransparency = 1,
        Text = title,
        Size = UDim2.new(1, -22, 0, 24),
        Position = UDim2.new(0, 16, 0, 4),
        Font = Enum.Font.GothamBold,
        TextSize = 13,
        TextColor3 = TH.text,
        TextXAlignment = Enum.TextXAlignment.Left,
    }, n)

    mk("TextLabel", {
        BackgroundTransparency = 1,
        Text = text,
        Size = UDim2.new(1, -22, 0, 24),
        Position = UDim2.new(0, 16, 0, 28),
        Font = Enum.Font.Gotham,
        TextSize = 11,
        TextColor3 = TH.subtext,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextWrapped = true,
    }, n)

    tw(n, 0.35, { Position = UDim2.new(1, -290, 1, -(idx * 68)) })

    taskLib.delay(duration or 4, function()
        tw(n, 0.35, { Position = UDim2.new(1, 10, 1, -(idx * 68)) })
        taskLib.wait(0.4)
        n:Destroy()
        notifCount -= 1
    end)
end

