-- ─── Compat shims ─────────────────────────────────────────────
local _mmr = (typeof(mousemoverel)=="function" and mousemoverel)
    or (typeof(Input)=="table" and Input.MouseMove)
    or nil
local _m1c = (typeof(mouse1click)=="function"  and mouse1click) or nil
local _m1p = (typeof(mouse1press)=="function"  and mouse1press) or nil
local _m1r = (typeof(mouse1release)=="function" and mouse1release) or nil
local _grm = (typeof(getrawmetatable)=="function" and getrawmetatable) or nil
local _sro = (typeof(setreadonly)=="function"     and setreadonly) or nil
local _ncc = (typeof(newcclosure)=="function"     and newcclosure) or nil
local _gnm = (typeof(getnamecallmethod)=="function" and getnamecallmethod) or nil
local _hkf = (typeof(hookfunction)=="function"    and hookfunction) or nil

-- ─── Theme ────────────────────────────────────────────────────
local C = {
    bg=Color3.fromRGB(11,12,17),    bg2=Color3.fromRGB(17,19,27),
    bg3=Color3.fromRGB(23,26,37),   acc=Color3.fromRGB(99,102,241),
    acc2=Color3.fromRGB(34,211,238), txt=Color3.fromRGB(226,232,240),
    sub=Color3.fromRGB(100,116,139), on=Color3.fromRGB(34,197,94),
    off=Color3.fromRGB(39,44,60),    bord=Color3.fromRGB(30,35,52),
    red=Color3.fromRGB(239,68,68),   orange=Color3.fromRGB(251,146,60),
}

local function cr(r,p) Instance.new("UICorner",p).CornerRadius=UDim.new(0,r) end
local function tw(o,t,p) TweenService:Create(o,TweenInfo.new(t,Enum.EasingStyle.Quart),p):Play() end
local function mk(cls,props,par)
    local i=Instance.new(cls); pcall(function() i.BorderSizePixel=0 end)
    for k,v in next,props do pcall(function() i[k]=v end) end
    if par then i.Parent=par end; return i
end
local function stroke(p,col,t)
    local s=Instance.new("UIStroke",p); s.Color=col or C.bord; s.Thickness=t or 1
    s.ApplyStrokeMode=Enum.ApplyStrokeMode.Border
end

-- ================================================================
--  KEY SYSTEM
-- ================================================================
local VALID_KEY = "ErogareVIP"
local keyOK = false

local KG=Instance.new("ScreenGui"); KG.Name="RscriptsX_Key"; KG.ResetOnSpawn=false; KG.DisplayOrder=1001
pcall(function() KG.Parent=game:GetService("CoreGui") end)
if not KG.Parent or not KG.Parent:IsA("CoreGui") then KG.Parent=LP:WaitForChild("PlayerGui") end

mk("Frame",{Size=UDim2.new(1,0,1,0),BackgroundColor3=Color3.fromRGB(5,5,10),BackgroundTransparency=0.35},KG)
local KW=mk("Frame",{Size=UDim2.new(0,380,0,240),Position=UDim2.new(0.5,-190,0.5,-120),BackgroundColor3=C.bg},KG); cr(12,KW); stroke(KW,C.bord,1)
local kt=mk("Frame",{Size=UDim2.new(1,0,0,3),BackgroundColor3=C.acc},KW); cr(3,kt); Instance.new("UIGradient",kt).Color=ColorSequence.new(C.acc,C.acc2)
mk("TextLabel",{BackgroundTransparency=1,Text="RscriptsX",Size=UDim2.new(1,0,0,40),Position=UDim2.new(0,0,0,18),Font=Enum.Font.GothamBold,TextSize=22,TextColor3=C.txt,TextXAlignment=Enum.TextXAlignment.Center},KW)
mk("TextLabel",{BackgroundTransparency=1,Text="Enter key to continue",Size=UDim2.new(1,0,0,22),Position=UDim2.new(0,0,0,56),Font=Enum.Font.Gotham,TextSize=13,TextColor3=C.sub,TextXAlignment=Enum.TextXAlignment.Center},KW)
local KB=mk("TextBox",{Size=UDim2.new(1,-48,0,40),Position=UDim2.new(0,24,0,92),BackgroundColor3=C.bg2,Text="",PlaceholderText="Paste key here...",Font=Enum.Font.Gotham,TextSize=14,TextColor3=C.txt,PlaceholderColor3=C.sub,TextXAlignment=Enum.TextXAlignment.Center,ClearTextOnFocus=false},KW); cr(8,KB); stroke(KB,C.bord,1)
local KS=mk("TextLabel",{BackgroundTransparency=1,Text="",Size=UDim2.new(1,0,0,20),Position=UDim2.new(0,0,0,138),Font=Enum.Font.Gotham,TextSize=12,TextColor3=C.sub,TextXAlignment=Enum.TextXAlignment.Center},KW)
local KBtn=mk("TextButton",{Size=UDim2.new(1,-48,0,38),Position=UDim2.new(0,24,0,168),BackgroundColor3=C.acc,Text="UNLOCK",TextColor3=Color3.new(1,1,1),TextSize=14,Font=Enum.Font.GothamBold,AutoButtonColor=false},KW); cr(8,KBtn)
KBtn.MouseEnter:Connect(function() tw(KBtn,.1,{BackgroundColor3=Color3.fromRGB(120,122,255)}) end)
KBtn.MouseLeave:Connect(function() tw(KBtn,.1,{BackgroundColor3=C.acc}) end)

local kDrag,kDS,kWS=false
KW.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then kDrag=true; kDS=i.Position; kWS=KW.Position end end)
UIS.InputChanged:Connect(function(i) if kDrag and i.UserInputType==Enum.UserInputType.MouseMovement then local d=i.Position-kDS; KW.Position=UDim2.new(kWS.X.Scale,kWS.X.Offset+d.X,kWS.Y.Scale,kWS.Y.Offset+d.Y) end end)
UIS.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then kDrag=false end end)

local function tryKey()
    if KB.Text:gsub("%s","") == VALID_KEY then
        keyOK=true; KS.TextColor3=C.on; KS.Text="Key accepted"
        task.wait(0.5); tw(KW,.3,{BackgroundTransparency=1}); task.wait(0.35); KG:Destroy()
    else
        KS.TextColor3=C.red; KS.Text="Wrong key"
        tw(KW,.04,{Position=UDim2.new(0.5,-198,0.5,-120)}); task.wait(.04)
        tw(KW,.04,{Position=UDim2.new(0.5,-182,0.5,-120)}); task.wait(.04)
        tw(KW,.04,{Position=UDim2.new(0.5,-190,0.5,-120)})
    end
end
KBtn.MouseButton1Click:Connect(tryKey)
KB.FocusLost:Connect(function(e) if e then tryKey() end end)

repeat task.wait() until keyOK

