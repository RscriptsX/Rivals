mk("TextLabel",{BackgroundTransparency=1,Text="v4.0 — Rivals",Size=UDim2.new(0,100,0,20),Position=UDim2.new(0,152,0.5,-4),Font=Enum.Font.Gotham,TextSize=11,TextColor3=C.sub,TextXAlignment=Enum.TextXAlignment.Left},Hdr)

