local GUI=Instance.new("ScreenGui"); GUI.Name="RscriptsX"; GUI.ResetOnSpawn=false
GUI.ZIndexBehavior=Enum.ZIndexBehavior.Sibling; GUI.DisplayOrder=999
pcall(function() GUI.IgnoreGuiInset=true end)
