-- ========== ESP ENGINE (with drawing fallback) ==========
local espPool = {}
local SKEL_R15 = {
    {"Head", "UpperTorso"},
    {"UpperTorso", "LowerTorso"},
    {"UpperTorso", "LeftUpperArm"},
    {"LeftUpperArm", "LeftLowerArm"},
    {"LeftLowerArm", "LeftHand"},
    {"UpperTorso", "RightUpperArm"},
    {"RightUpperArm", "RightLowerArm"},
    {"RightLowerArm", "RightHand"},
    {"LowerTorso", "LeftUpperLeg"},
    {"LeftUpperLeg", "LeftLowerLeg"},
    {"LeftLowerLeg", "LeftFoot"},
    {"LowerTorso", "RightUpperLeg"},
    {"RightUpperLeg", "RightLowerLeg"},
    {"RightLowerLeg", "RightFoot"},
}

local SKEL_R6 = {
    {"Head", "Torso"},
    {"Torso", "Left Arm"},
    {"Torso", "Right Arm"},
    {"Torso", "Left Leg"},
    {"Torso", "Right Leg"},
}

if drawingSupported then
    local function createESPObject(player)
        if player == LP then return end
        local D = Drawing.new

        local e = {}
        e.box = D("Square")
        e.box.Filled = false
        e.box.Thickness = 1.4
        e.box.Visible = false

        e.boxOutline = D("Square")
        e.boxOutline.Filled = false
        e.boxOutline.Thickness = 3
        e.boxOutline.Color = Color3.fromRGB(0, 0, 0)
        e.boxOutline.Visible = false

        e.fill = D("Square")
        e.fill.Filled = true
        e.fill.Transparency = 0.82
        e.fill.Visible = false

        e.corners = {}
        for i = 1, 8 do
            local l = D("Line")
            l.Thickness = 2
            l.Visible = false
            e.corners[i] = l
        end
        e.cornerOutlines = {}
        for i = 1, 8 do
            local l = D("Line")
            l.Thickness = 4
            l.Color = Color3.fromRGB(0, 0, 0)
            l.Visible = false
            e.cornerOutlines[i] = l
        end

        e.name = D("Text")
        e.name.Center = true
        e.name.Outline = true
        e.name.OutlineColor = Color3.fromRGB(0, 0, 0)
        e.name.Size = 13
        e.name.Font = Drawing.Fonts.UI
        e.name.Visible = false

        e.nameBG = D("Square")
        e.nameBG.Filled = true
        e.nameBG.Color = Color3.fromRGB(0, 0, 0)
        e.nameBG.Transparency = 0.45
        e.nameBG.Visible = false

        e.dist = D("Text")
        e.dist.Center = true
        e.dist.Outline = true
        e.dist.OutlineColor = Color3.fromRGB(0, 0, 0)
        e.dist.Size = 11
        e.dist.Font = Drawing.Fonts.UI
        e.dist.Color = Color3.fromRGB(180, 185, 200)
        e.dist.Visible = false

        e.hpBG = D("Square")
        e.hpBG.Filled = true
        e.hpBG.Color = Color3.fromRGB(10, 10, 10)
        e.hpBG.Visible = false

        e.hpOutline = D("Square")
        e.hpOutline.Filled = false
        e.hpOutline.Thickness = 1
        e.hpOutline.Color = Color3.fromRGB(0, 0, 0)
        e.hpOutline.Visible = false

        e.hpFill = D("Square")
        e.hpFill.Filled = true
        e.hpFill.Visible = false

        e.tracer = D("Line")
        e.tracer.Thickness = 1.2
        e.tracer.Visible = false

        e.headDot = D("Circle")
        e.headDot.Filled = true
        e.headDot.Radius = 4
        e.headDot.Visible = false

        e.headDotOut = D("Circle")
        e.headDotOut.Filled = false
        e.headDotOut.Thickness = 1.5
        e.headDotOut.Color = Color3.fromRGB(0, 0, 0)
        e.headDotOut.Radius = 5
        e.headDotOut.Visible = false

        e.targetDot = D("Circle")
        e.targetDot.Filled = true
        e.targetDot.Radius = 6
        e.targetDot.Color = Color3.fromRGB(0, 255, 180)
        e.targetDot.Visible = false

        e.targetDotOut = D("Circle")
        e.targetDotOut.Filled = false
        e.targetDotOut.Thickness = 2
        e.targetDotOut.Color = Color3.fromRGB(0, 0, 0)
        e.targetDotOut.Radius = 7
        e.targetDotOut.Visible = false

        e.skeleton = {}
        for i = 1, 14 do
            local l = D("Line")
            l.Thickness = 1.5
            l.Visible = false
            e.skeleton[i] = l
        end

        espPool[player] = e
    end

    local function destroyESPObject(player)
        local e = espPool[player]
        if not e then return end
        for key, val in pairs(e) do
            if type(val) == "table" then
                for _, obj in ipairs(val) do
                    pcall(function() obj:Remove() end)
                end
            else
                pcall(function() val:Remove() end)
            end
        end
        espPool[player] = nil
    end

    local function hideAll(e)
        for key, val in pairs(e) do
            if type(val) == "table" then
                for _, obj in ipairs(val) do
                    obj.Visible = false
                end
            else
                val.Visible = false
            end
        end
    end

    local function drawCornerBox(e, x, y, w, h, col)
        local cw = w * 0.22
        local ch = h * 0.22
        local data = {
            {x, y, x+cw, y, x, y, x, y+ch},
            {x+w, y, x+w-cw, y, x+w, y, x+w, y+ch},
            {x, y+h, x+cw, y+h, x, y+h, x, y+h-ch},
            {x+w, y+h, x+w-cw, y+h, x+w, y+h, x+w, y+h-ch},
        }
        local idx = 1
        for _, d in ipairs(data) do
            e.cornerOutlines[idx].From = Vector2.new(d[1], d[2])
            e.cornerOutlines[idx].To = Vector2.new(d[3], d[4])
            e.cornerOutlines[idx].Visible = true
            e.corners[idx].From = Vector2.new(d[1], d[2])
            e.corners[idx].To = Vector2.new(d[3], d[4])
            e.corners[idx].Color = col
            e.corners[idx].Visible = true
            idx += 1

            e.cornerOutlines[idx].From = Vector2.new(d[5], d[6])
            e.cornerOutlines[idx].To = Vector2.new(d[7], d[8])
            e.cornerOutlines[idx].Visible = true
            e.corners[idx].From = Vector2.new(d[5], d[6])
            e.corners[idx].To = Vector2.new(d[7], d[8])
            e.corners[idx].Color = col
            e.corners[idx].Visible = true
            idx += 1
        end
    end

    local function drawSkeleton(e, character, color)
        local isR15 = character:FindFirstChild("UpperTorso") ~= nil
        local connections = isR15 and SKEL_R15 or SKEL_R6
        for i, conn in ipairs(connections) do
            local partA = character:FindFirstChild(conn[1])
            local partB = character:FindFirstChild(conn[2])
            if partA and partB then
                local spA, onA = Camera:WorldToViewportPoint(partA.Position)
                local spB, onB = Camera:WorldToViewportPoint(partB.Position)
                if onA and onB then
                    e.skeleton[i].From = Vector2.new(spA.X, spA.Y)
                    e.skeleton[i].To = Vector2.new(spB.X, spB.Y)
                    e.skeleton[i].Color = color
                    e.skeleton[i].Visible = true
                else
                    e.skeleton[i].Visible = false
                end
            else
                e.skeleton[i].Visible = false
            end
        end
        for i = #connections + 1, 14 do
            e.skeleton[i].Visible = false
        end
    end

    local function updateAllESP()
        for player, e in pairs(espPool) do
            local ch = player.Character
            local hm = ch and ch:FindFirstChildOfClass("Humanoid")
            local root = ch and ch:FindFirstChild("HumanoidRootPart")
            local head = ch and ch:FindFirstChild("Head")
            local worldDist = root and (root.Position - Camera.CFrame.Position).Magnitude or 9999

            local show = CFG.ESP.On
                and ch and hm and root and head
                and hm.Health > 0
                and worldDist <= CFG.ESP.MaxDist
                and not (CFG.ESP.Team and sameTeam(player))

            if not show then
                hideAll(e)
                continue
            end

            local rootSP, onScreen = Camera:WorldToViewportPoint(root.Position)
            local headSP = Camera:WorldToViewportPoint(head.Position + Vector3.new(0, 0.5, 0))

            if not onScreen then
                hideAll(e)
                continue
            end

            local scale = 1 / rootSP.Z * 380
            local boxW = scale * 1.15
            local boxH = scale * 2.8
            local boxX = rootSP.X - boxW / 2
            local boxY = headSP.Y - 4

            local col = CFG.ESP.BoxColor
            local dist = math.floor(worldDist)

            if CFG.ESP.Style == "Corner" then
                e.box.Visible = false
                e.boxOutline.Visible = false
                e.fill.Visible = false
                if CFG.ESP.Boxes then
                    drawCornerBox(e, boxX, boxY, boxW, boxH, col)
                    if CFG.ESP.Fill then
                        e.fill.Position = Vector2.new(boxX, boxY)
                        e.fill.Size = Vector2.new(boxW, boxH)
                        e.fill.Color = col
                        e.fill.Visible = true
                    end
                else
                    for i = 1, 8 do e.corners[i].Visible = false; e.cornerOutlines[i].Visible = false end
                end
            else
                for i = 1, 8 do e.corners[i].Visible = false; e.cornerOutlines[i].Visible = false end
                if CFG.ESP.Boxes then
                    e.boxOutline.Position = Vector2.new(boxX - 1, boxY - 1)
                    e.boxOutline.Size = Vector2.new(boxW + 2, boxH + 2)
                    e.boxOutline.Visible = true

                    e.box.Position = Vector2.new(boxX, boxY)
                    e.box.Size = Vector2.new(boxW, boxH)
                    e.box.Color = col
                    e.box.Visible = true

                    if CFG.ESP.Fill then
                        e.fill.Position = Vector2.new(boxX, boxY)
                        e.fill.Size = Vector2.new(boxW, boxH)
                        e.fill.Color = col
                        e.fill.Visible = true
                    else
                        e.fill.Visible = false
                    end
                else
                    e.box.Visible = false
                    e.boxOutline.Visible = false
                    e.fill.Visible = false
                end
            end

            if CFG.ESP.Names then
                local nameText = player.DisplayName
                local nameY = boxY - 18
                e.name.Position = Vector2.new(rootSP.X, nameY)
                e.name.Text = nameText
                e.name.Color = CFG.ESP.NameColor
                e.name.Visible = true
                if CFG.ESP.NameBG then
                    local textW = #nameText * 6.5
                    e.nameBG.Position = Vector2.new(rootSP.X - textW/2 - 3, nameY - 2)
                    e.nameBG.Size = Vector2.new(textW + 6, 16)
                    e.nameBG.Visible = true
                else
                    e.nameBG.Visible = false
                end
            else
                e.name.Visible = false
                e.nameBG.Visible = false
            end

            if CFG.ESP.Dist then
                e.dist.Position = Vector2.new(rootSP.X, boxY + boxH + 3)
                e.dist.Text = dist .. "m"
                e.dist.Visible = true
            else
                e.dist.Visible = false
            end

            if CFG.ESP.Health then
                local hp = math.clamp(hm.Health / hm.MaxHealth, 0, 1)
                local barX = boxX - 8
                local barW = 4
                local barH = boxH
                e.hpBG.Position = Vector2.new(barX, boxY)
                e.hpBG.Size = Vector2.new(barW, barH)
                e.hpBG.Visible = true
                e.hpOutline.Position = Vector2.new(barX - 1, boxY - 1)
                e.hpOutline.Size = Vector2.new(barW + 2, barH + 2)
                e.hpOutline.Visible = true
                local hpColor = Color3.fromRGB(
                    math.floor(255 * (1 - hp)),
                    math.floor(255 * hp),
                    0
                )
                e.hpFill.Position = Vector2.new(barX, boxY + barH * (1 - hp))
                e.hpFill.Size = Vector2.new(barW, barH * hp)
                e.hpFill.Color = hpColor
                e.hpFill.Visible = true
            else
                e.hpBG.Visible = false
                e.hpOutline.Visible = false
                e.hpFill.Visible = false
            end

            if CFG.ESP.Tracers then
                local origin
                if CFG.ESP.TracerOrigin == "Top" then
                    origin = Vector2.new(Camera.ViewportSize.X / 2, 0)
                elseif CFG.ESP.TracerOrigin == "Center" then
                    origin = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
                else
                    origin = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
                end
                e.tracer.From = origin
                e.tracer.To = Vector2.new(rootSP.X, boxY + boxH)
                e.tracer.Color = CFG.ESP.TracerColor
                e.tracer.Visible = true
            else
                e.tracer.Visible = false
            end

            if CFG.ESP.HeadDot then
                local hsp = Camera:WorldToViewportPoint(head.Position)
                e.headDot.Position = Vector2.new(hsp.X, hsp.Y)
                e.headDot.Color = col
                e.headDot.Visible = true
                e.headDotOut.Position = Vector2.new(hsp.X, hsp.Y)
                e.headDotOut.Visible = true
            else
                e.headDot.Visible = false
                e.headDotOut.Visible = false
            end

            if CFG.ESP.Skeleton then
                drawSkeleton(e, ch, CFG.ESP.SkeletonColor)
            else
                for i = 1, 14 do e.skeleton[i].Visible = false end
            end

            if CFG.SA.On and CFG.SA.Dot and silentTarget == player then
                local tp = ch:FindFirstChild(CFG.SA.Part)
                if tp then
                    local tsp = Camera:WorldToViewportPoint(tp.Position)
                    e.targetDot.Position = Vector2.new(tsp.X, tsp.Y)
                    e.targetDot.Visible = true
                    e.targetDotOut.Position = Vector2.new(tsp.X, tsp.Y)
                    e.targetDotOut.Visible = true
                else
                    e.targetDot.Visible = false
                    e.targetDotOut.Visible = false
                end
            else
                e.targetDot.Visible = false
                e.targetDotOut.Visible = false
            end
        end
    end

    -- Initialize ESP for current players
    for _, player in ipairs(Players:GetPlayers()) do
        createESPObject(player)
    end

    Players.PlayerAdded:Connect(function(player)
        createESPObject(player)
        player.CharacterAdded:Connect(function(ch)
            taskLib.wait(0.5)
            if not espPool[player] then createESPObject(player) end
            if CFG.ESP.Chams and player ~= LP then
                local h = Instance.new("Highlight", ch)
                h.FillColor = Color3.fromRGB(255, 30, 30)
                h.OutlineColor = Color3.new(1, 1, 1)
                h.FillTransparency = 0.5
            end
        end)
    end)

    Players.PlayerRemoving:Connect(destroyESPObject)

    for _, player in ipairs(Players:GetPlayers()) do
        player.CharacterAdded:Connect(function(ch)
            taskLib.wait(0.5)
            if not espPool[player] then createESPObject(player) end
            if CFG.ESP.Chams and player ~= LP then
                local h = Instance.new("Highlight", ch)
                h.FillColor = Color3.fromRGB(255, 30, 30)
                h.OutlineColor = Color3.new(1, 1, 1)
                h.FillTransparency = 0.5
            end
        end)
    end
else
    -- No drawing – disable ESP entirely
    function updateAllESP() end
    warn("Drawing library not available – ESP disabled")
end

-- ========== AIMBOT ENGINE ==========
local fovCircle, fovOutline, saFOV = nil, nil, nil
if drawingSupported then
    fovCircle = Drawing.new("Circle")
    fovCircle.Visible = false
    fovCircle.Filled = false
    fovCircle.Thickness = 1.5
    fovCircle.NumSides = 80
    fovCircle.Color = Color3.fromRGB(200, 205, 255)
    fovCircle.Transparency = 0.7

    fovOutline = Drawing.new("Circle")
    fovOutline.Visible = false
    fovOutline.Filled = false
    fovOutline.Thickness = 3
    fovOutline.NumSides = 80
    fovOutline.Color = Color3.fromRGB(0, 0, 0)
    fovOutline.Transparency = 0.5

    saFOV = Drawing.new("Circle")
    saFOV.Visible = false
    saFOV.Filled = false
    saFOV.Thickness = 1
    saFOV.NumSides = 60
    saFOV.Color = Color3.fromRGB(255, 180, 0)
    saFOV.Transparency = 0.6
else
    fovCircle = { Visible = false }
    fovOutline = { Visible = false }
    saFOV = { Visible = false }
end

local aimKeyCheckers = {
    RMB = function() return UIS:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) end,
    LMB = function() return UIS:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) end,
    Q = function() return UIS:IsKeyDown(Enum.KeyCode.Q) end,
    E = function() return UIS:IsKeyDown(Enum.KeyCode.E) end,
    Z = function() return UIS:IsKeyDown(Enum.KeyCode.Z) end,
    X = function() return UIS:IsKeyDown(Enum.KeyCode.X) end,
    C = function() return UIS:IsKeyDown(Enum.KeyCode.C) end,
    V = function() return UIS:IsKeyDown(Enum.KeyCode.V) end,
}

local function isAimKeyHeld()
    local checker = aimKeyCheckers[CFG.Aim.Key]
    if checker then
        return checker()
    end
    return false
end

local function doAimbot(targetPos, instant)
    local screenPos, onScreen = Camera:WorldToViewportPoint(targetPos)
    if not onScreen then return end

    local cx = Camera.ViewportSize.X / 2
    local cy = Camera.ViewportSize.Y / 2
    local dx = (screenPos.X - cx) * CFG.Aim.Sens
    local dy = (screenPos.Y - cy) * CFG.Aim.Sens

    if instant then
        if EXEC.mmr then
            pcall(EXEC.mmr, dx, dy)
        else
            Camera.CFrame = CFrame.new(Camera.CFrame.Position, targetPos)
        end
    else
        local smooth = CFG.Aim.Smooth / 100
        if EXEC.mmr then
            pcall(EXEC.mmr, dx * smooth, dy * smooth)
        else
            Camera.CFrame = Camera.CFrame:Lerp(
                CFrame.new(Camera.CFrame.Position, targetPos),
                smooth
            )
        end
    end
end

-- ========== SILENT AIM HOOKS ==========
local hookStatus = {
    mouseHit = false,
    raycast = false,
    fireServer = false,
}

local function getSilentTarget()
    if not CFG.SA.On and not CFG.Rage.On then
        silentTarget = nil
        return nil, nil
    end

    if math.random(1, 100) > CFG.SA.HitChance then
        return nil, nil
    end

    local target = getClosest(
        CFG.SA.FOVCheck and CFG.SA.FOV or nil,
        CFG.SA.Part,
        CFG.SA.Team,
        false,
        CFG.Rage.On and CFG.Rage.Priority or "Closest"
    )

    if not target then
        silentTarget = nil
        return nil, nil
    end

    silentTarget = target
    local ch = target.Character
    local part = ch and ch:FindFirstChild(CFG.SA.Part)
    return target, part
end

local function deepReplace(args, targetPart)
    for i, v in ipairs(args) do
        if typeof(v) == "Vector3" then
            args[i] = targetPart.Position
        elseif typeof(v) == "CFrame" then
            args[i] = CFrame.new(targetPart.Position)
        elseif typeof(v) == "Instance" then
            if v:IsA("BasePart") then
                local owner = Players:GetPlayerFromCharacter(v.Parent)
                    or Players:GetPlayerFromCharacter(v.Parent and v.Parent.Parent)
                if owner and owner ~= LP then
                    args[i] = targetPart
                end
            elseif v:IsA("Model") then
                local owner = Players:GetPlayerFromCharacter(v)
                if owner and owner ~= LP then
                    args[i] = targetPart.Parent
                end
            end
        elseif type(v) == "table" then
            for k2, v2 in pairs(v) do
                if typeof(v2) == "Vector3" then
                    v[k2] = targetPart.Position
                elseif typeof(v2) == "CFrame" then
                    v[k2] = CFrame.new(targetPart.Position)
                elseif typeof(v2) == "Instance" and v2:IsA("BasePart") then
                    local owner = Players:GetPlayerFromCharacter(v2.Parent)
                        or Players:GetPlayerFromCharacter(v2.Parent and v2.Parent.Parent)
                    if owner and owner ~= LP then
                        v[k2] = targetPart
                    end
                elseif type(v2) == "table" then
                    for k3, v3 in pairs(v2) do
                        if typeof(v3) == "Vector3" then
                            v2[k3] = targetPart.Position
                        elseif typeof(v3) == "CFrame" then
                            v2[k3] = CFrame.new(targetPart.Position)
                        elseif typeof(v3) == "Instance" and v3:IsA("BasePart") then
                            local owner = Players:GetPlayerFromCharacter(v3.Parent)
                                or Players:GetPlayerFromCharacter(v3.Parent and v3.Parent.Parent)
                            if owner and owner ~= LP then
                                v2[k3] = targetPart
                            end
                        elseif type(v3) == "table" then
                            for k4, v4 in pairs(v3) do
                                if typeof(v4) == "Vector3" then
                                    v3[k4] = targetPart.Position
                                elseif typeof(v4) == "CFrame" then
                                    v3[k4] = CFrame.new(targetPart.Position)
                                end
                            end
                        end
                    end
                end
            end
        end
    end
    return args
end

-- Hook installation with safe checks
if EXEC.grm and EXEC.sro and EXEC.ncc then
    pcall(function()
        local mt = EXEC.grm(game)
        local oldIndex = mt.__index
        EXEC.sro(mt, false)
        mt.__index = wrapCC(function(self, key)
            local isSelf = false
            if EXEC.cc then
                isSelf = EXEC.cc()
            else
                isSelf = _selfCall
            end
            if not isSelf and (CFG.SA.On or CFG.Rage.On) then
                local isMouseObj = false
                pcall(function()
                    isMouseObj = (self == Mouse) or (tostring(self) == "Mouse") or (self:IsA and self:IsA("Mouse")) or (self:IsA and self:IsA("PlayerMouse"))
                end)
                if isMouseObj then
                    local _, part = getSilentTarget()
                    if part then
                        if key == "Hit" then
                            return CFrame.new(part.Position)
                        elseif key == "Target" then
                            return part
                        elseif key == "UnitRay" then
                            local origin = Camera.CFrame.Position
                            local dir = (part.Position - origin).Unit
                            return Ray.new(origin, dir)
                        elseif key == "X" then
                            local sp = Camera:WorldToViewportPoint(part.Position)
                            return sp.X
                        elseif key == "Y" then
                            local sp = Camera:WorldToViewportPoint(part.Position)
                            return sp.Y
                        end
                    end
                end
            end
            return oldIndex(self, key)
        end)
        EXEC.sro(mt, true)
        hookStatus.mouseHit = true
    end)
end

if EXEC.grm and EXEC.sro and EXEC.ncc and EXEC.gnm then
    pcall(function()
        local mt = EXEC.grm(game)
        local oldNamecall = mt.__namecall
        EXEC.sro(mt, false)
        mt.__namecall = wrapCC(function(self, ...)
            local method = EXEC.gnm()
            local args = {...}
            local isSelf = false
            if EXEC.cc then isSelf = EXEC.cc() else isSelf = _selfCall end
            if not isSelf and (CFG.SA.On or CFG.Rage.On) then
                if method == "Raycast" and self == workspace then
                    local _, part = getSilentTarget()
                    if part and typeof(args[1]) == "Vector3" and typeof(args[2]) == "Vector3" then
                        local origin = args[1]
                        local newDir = (part.Position - origin)
                        hookStatus.raycast = true
                        return oldNamecall(self, origin, newDir, select(3, ...))
                    end
                end
                if method == "FireServer" or method == "InvokeServer" then
                    local _, part = getSilentTarget()
                    if part then
                        deepReplace(args, part)
                        hookStatus.fireServer = true
                        return oldNamecall(self, table.unpack(args))
                    end
                end
            end
            return oldNamecall(self, ...)
        end)
        EXEC.sro(mt, true)
    end)
end

if not hookStatus.fireServer and EXEC.hkf and EXEC.ncc then
    pcall(function()
        local oldFS
        oldFS = EXEC.hkf(
            Instance.new("RemoteEvent").FireServer,
            wrapCC(function(self, ...)
                if CFG.SA.On or CFG.Rage.On then
                    local _, part = getSilentTarget()
                    if part then
                        local args = {...}
                        deepReplace(args, part)
                        hookStatus.fireServer = true
                        return oldFS(self, table.unpack(args))
                    end
                end
                return oldFS(self, ...)
            end)
        )
    end)
end

-- ========== ONE-TIME EVENT CONNECTIONS ==========
UIS.JumpRequest:Connect(function()
    if CFG.Misc.InfJump then
        local ch = LP.Character
        local hm = ch and ch:FindFirstChildOfClass("Humanoid")
        if hm then
            hm:ChangeState(Enum.HumanoidStateType.Jumping)
        end
    end
end)

LP.Idled:Connect(function()
    if CFG.Misc.AntiAFK then
        pcall(function()
            local vu = game:GetService("VirtualUser")
            vu:Button2Down(Vector2.new(0, 0), Camera.CFrame)
            taskLib.wait(0.1)
            vu:Button2Up(Vector2.new(0, 0), Camera.CFrame)
        end)
    end
end)

RunService.RenderStepped:Connect(function()
    Camera = workspace.CurrentCamera
end)

-- ========== HUD OVERLAY ==========
local watermark, targetInfo = nil, nil
if drawingSupported then
    watermark = Drawing.new("Text")
    watermark.Text = "RscriptsX v5.0"
    watermark.Size = 14
    watermark.Font = Drawing.Fonts.UI
    watermark.Color = Color3.fromRGB(200, 200, 220)
    watermark.Outline = true
    watermark.OutlineColor = Color3.fromRGB(0, 0, 0)
    watermark.Position = Vector2.new(10, 6)
    watermark.Visible = true

    targetInfo = Drawing.new("Text")
    targetInfo.Text = ""
    targetInfo.Size = 12
    targetInfo.Font = Drawing.Fonts.UI
    targetInfo.Color = Color3.fromRGB(0, 220, 200)
    targetInfo.Outline = true
    targetInfo.OutlineColor = Color3.fromRGB(0, 0, 0)
    targetInfo.Position = Vector2.new(10, 24)
    targetInfo.Visible = true
else
    watermark = { Visible = false }
    targetInfo = { Visible = false }
end

-- ========== MAIN RENDER LOOP ==========
RunService.RenderStepped:Connect(function()
    local vp = Camera.ViewportSize
    local cx = vp.X / 2
    local cy = vp.Y / 2

    if drawingSupported then
        fovOutline.Position = Vector2.new(cx, cy)
        fovOutline.Radius = CFG.Aim.FOV + 1
        fovOutline.Visible = CFG.Aim.Circle and (CFG.Aim.On or CFG.Rage.On)

        fovCircle.Position = Vector2.new(cx, cy)
        fovCircle.Radius = CFG.Aim.FOV
        fovCircle.Visible = CFG.Aim.Circle and (CFG.Aim.On or CFG.Rage.On)

        saFOV.Position = Vector2.new(cx, cy)
        saFOV.Radius = CFG.SA.FOV
        saFOV.Visible = CFG.SA.On and CFG.SA.FOVCheck
    end

    if drawingSupported then
        updateAllESP()
    end

    if CFG.Rage.On then
        local target = getClosest(
            nil,
            "Head",
            CFG.Aim.Team,
            false,
            CFG.Rage.Priority
        )
        if target then
            local ch = target.Character
            local part = ch and ch:FindFirstChild("Head")
            if part then
                local root = ch:FindFirstChild("HumanoidRootPart")
                local vel = root and root.Velocity or Vector3.zero
                local predicted = part.Position + vel * (CFG.Aim.Pred / 100)
                doAimbot(predicted, true)
                if CFG.Rage.AutoFire then
                    if EXEC.m1c then
                        pcall(EXEC.m1c)
                    elseif EXEC.m1p and EXEC.m1r then
                        pcall(EXEC.m1p)
                        taskLib.defer(function() pcall(EXEC.m1r) end)
                    end
                end
                footerTarget.Text = "Target: " .. target.DisplayName
                if drawingSupported and targetInfo then
                    targetInfo.Text = "RAGE >> " .. target.DisplayName
                end
            end
        else
            footerTarget.Text = "Target: None"
            if drawingSupported and targetInfo then targetInfo.Text = "" end
        end

        if CFG.Rage.AntiAim then
            local myRoot = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
            if myRoot then
                pcall(function()
                    local angle = math.rad(tick() * 2000 % 360)
                    myRoot.CFrame = CFrame.new(myRoot.Position) * CFrame.Angles(0, angle, 0)
                end)
            end
        end

    elseif CFG.Aim.On and isAimKeyHeld() then
        local target = getClosest(
            CFG.Aim.FOV,
            CFG.Aim.Part,
            CFG.Aim.Team,
            CFG.Aim.VisCheck,
            "Closest"
        )
        if target then
            local ch = target.Character
            local part = ch and ch:FindFirstChild(CFG.Aim.Part)
            if part then
                local root = ch:FindFirstChild("HumanoidRootPart")
                local vel = root and root.Velocity or Vector3.zero
                local predicted = part.Position + vel * (CFG.Aim.Pred / 100)
                doAimbot(predicted, false)
                footerTarget.Text = "Target: " .. target.DisplayName
                if drawingSupported and targetInfo then
                    targetInfo.Text = "AIM >> " .. target.DisplayName
                end
            end
        else
            footerTarget.Text = "Target: None"
            if drawingSupported and targetInfo then targetInfo.Text = "" end
        end
    else
        if not CFG.Rage.On then
            footerTarget.Text = "Target: None"
            if drawingSupported and targetInfo then targetInfo.Text = "" end
        end
    end

    if CFG.Misc.Fly and flyBV and flyBG then
        local root = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
        if root then
            local vel = Vector3.zero
            local spd = CFG.Misc.FlySpeed
            if UIS:IsKeyDown(Enum.KeyCode.W) then vel += Camera.CFrame.LookVector * spd end
            if UIS:IsKeyDown(Enum.KeyCode.S) then vel -= Camera.CFrame.LookVector * spd end
            if UIS:IsKeyDown(Enum.KeyCode.A) then vel -= Camera.CFrame.RightVector * spd end
            if UIS:IsKeyDown(Enum.KeyCode.D) then vel += Camera.CFrame.RightVector * spd end
            if UIS:IsKeyDown(Enum.KeyCode.Space) then vel += Vector3.new(0, spd, 0) end
            if UIS:IsKeyDown(Enum.KeyCode.LeftShift) then vel -= Vector3.new(0, spd, 0) end
            flyBV.Velocity = vel
            flyBG.CFrame = Camera.CFrame
        end
    end

    if CFG.Misc.Noclip then
        local ch = LP.Character
        if ch then
            for _, p in ipairs(ch:GetDescendants()) do
                if p:IsA("BasePart") then
                    p.CanCollide = false
                end
            end
        end
    end
end)

-- ========== TOGGLE GUI VISIBILITY ==========
local guiVisible = true
UIS.InputBegan:Connect(function(input, processed)
    if processed then return end
    if input.KeyCode == Enum.KeyCode.RightShift then
        guiVisible = not guiVisible
        Win.Visible = guiVisible
    end
end)

-- ========== STARTUP NOTIFICATIONS ==========
taskLib.delay(0.3, function()
    Notify("RscriptsX v5.0", "Loaded successfully — key authenticated", 4, TH.green)
end)

taskLib.delay(1, function()
    if EXEC.mmr then
        Notify("Aimbot", "mousemoverel ready — accurate input sim", 3, TH.green)
    else
        Notify("Aimbot", "mousemoverel MISSING — using camera fallback", 4, TH.orange)
    end
end)

taskLib.delay(1.5, function()
    local hookCount = 0
    if hookStatus.mouseHit then hookCount += 1 end
    hookCount += 1
    hookCount += 1
    if hookStatus.mouseHit then
        Notify("Silent Aim", "TRIPLE HOOK installed (Mouse + Ray + Fire)", 4, TH.green)
    elseif EXEC.grm then
        Notify("Silent Aim", "Hooks installed (Ray + FireServer)", 4, TH.accent2)
    elseif EXEC.hkf then
        Notify("Silent Aim", "FireServer hook only (partial)", 4, TH.orange)
    else
        Notify("Silent Aim", "NO HOOKS — executor unsupported", 4, TH.red)
    end
end)

taskLib.delay(2, function()
    Notify("Controls", "RightShift to toggle GUI", 3, TH.accent)
end)

-- ========== CLEANUP ON DESTROY ==========
GUI.Destroying:Connect(function()
    if drawingSupported then
        for _, e in pairs(espPool) do
            for key, val in pairs(e) do
                if type(val) == "table" then
                    for _, obj in ipairs(val) do pcall(function() obj:Remove() end) end
                else
                    pcall(function() val:Remove() end)
                end
            end
        end
        pcall(function() if fovCircle then fovCircle:Remove() end end)
        pcall(function() if fovOutline then fovOutline:Remove() end end)
        pcall(function() if saFOV then saFOV:Remove() end end)
        pcall(function() if watermark then watermark:Remove() end end)
        pcall(function() if targetInfo then targetInfo:Remove() end end)
    end
    disableWB()
    disableFly()
end)

-- End of RscriptsX v5.0 (Xeno compatible)
