-- ========== COMPATIBILITY LAYER ==========
local function safe()
    local ok, err = xpcall(function() return end, function(e) return e end)
    return not err
end

local function warn(...)
    print("[RscriptsX]", ...)
end

-- Fallback for task library
local taskLib = task or {}
taskLib.wait = taskLib.wait or wait
taskLib.delay = taskLib.delay or delay
taskLib.spawn = taskLib.spawn or spawn

