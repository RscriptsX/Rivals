-- ═══════════════════ TAB CONTENT ══════════════════════════════

-- ESP
Sec(tESP,"VISIBILITY")
Toggle(tESP,"Enable ESP",false,function(v) CFG.ESP.On=v end)
Toggle(tESP,"Boxes",true,function(v) CFG.ESP.Boxes=v end)
Toggle(tESP,"Fill Boxes",false,function(v) CFG.ESP.Fill=v end)
Toggle(tESP,"Names",true,function(v) CFG.ESP.Names=v end)
Toggle(tESP,"Health Bars",true,function(v) CFG.ESP.Health=v end)
Toggle(tESP,"Distance",true,function(v) CFG.ESP.Dist=v end)
Toggle(tESP,"Tracers",false,function(v) CFG.ESP.Tracers=v end)
Toggle(tESP,"Head Dots",false,function(v) CFG.ESP.HeadDot=v end)
Toggle(tESP,"Chams",false,function(v)
    CFG.ESP.Chams=v
    for _,p in ipairs(Players:GetPlayers()) do
        if p~=LP and p.Character then
            local h=p.Character:FindFirstChildOfClass("Highlight")
            if v then if not h then h=Instance.new("Highlight",p.Character); h.FillColor=Color3.fromRGB(255,30,30); h.OutlineColor=Color3.new(1,1,1); h.FillTransparency=0.5 end
            else if h then h:Destroy() end end
        end
    end
end)
