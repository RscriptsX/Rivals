-- ========== HELPER FUNCTIONS ==========
local function cr(radius, parent)
    local c = Instance.new("UICorner", parent)
    c.CornerRadius = UDim.new(0, radius)
    return c
end

local function tw(obj, duration, props)
    TweenService:Create(obj, TweenInfo.new(duration, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), props):Play()
end

local function mk(className, props, parent)
    local inst = Instance.new(className)
    pcall(function() inst.BorderSizePixel = 0 end)
    for k, v in pairs(props) do
        pcall(function() inst[k] = v end)
    end
    if parent then inst.Parent = parent end
    return inst
end

local function addStroke(parent, color, thickness)
    local s = Instance.new("UIStroke", parent)
    s.Color = color or TH.border
    s.Thickness = thickness or 1
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    return s
end

local function addGradient(parent, c1, c2)
    local g = Instance.new("UIGradient", parent)
    g.Color = ColorSequence.new(c1 or TH.accent, c2 or TH.accent2)
    return g
end

-- ========== CORE UTILITY ==========
local silentTarget = nil

local function sameTeam(player)
    return LP.Team ~= nil and player.Team == LP.Team
end

local function isAlive(player)
    local ch = player.Character
    local hm = ch and ch:FindFirstChildOfClass("Humanoid")
    return ch and hm and hm.Health > 0
end

local function isVisible(worldPos)
    local origin = Camera.CFrame.Position
    local direction = worldPos - origin
    local rp = RaycastParams.new()
    rp.FilterDescendantsInstances = { LP.Character or Instance.new("Model") }
    rp.FilterType = Enum.RaycastFilterType.Exclude
    local result = workspace:Raycast(origin, direction, rp)
    if not result then return true end
    local hitPlayer = Players:GetPlayerFromCharacter(result.Instance.Parent)
        or Players:GetPlayerFromCharacter(result.Instance.Parent and result.Instance.Parent.Parent)
    return hitPlayer ~= nil and hitPlayer ~= LP
end

local function getClosest(fov, partName, teamCheck, visCheck, priority)
    local best = nil
    local bestScore = math.huge
    local cx = Camera.ViewportSize.X / 2
    local cy = Camera.ViewportSize.Y / 2

    for _, player in ipairs(Players:GetPlayers()) do
        if player == LP then continue end
        if teamCheck and sameTeam(player) then continue end

        local ch = player.Character
        if not ch then continue end
        local hm = ch:FindFirstChildOfClass("Humanoid")
        if not hm or hm.Health <= 0 then continue end
        local part = ch:FindFirstChild(partName)
        if not part then continue end

        if visCheck and not isVisible(part.Position) then continue end

        local screenPos, onScreen = Camera:WorldToViewportPoint(part.Position)
        if not onScreen then continue end

        local screenDist = math.sqrt((screenPos.X - cx)^2 + (screenPos.Y - cy)^2)
        if fov and screenDist > fov then continue end

        local worldDist = (part.Position - Camera.CFrame.Position).Magnitude
        local hp = hm.Health

        local score
        if priority == "Lowest HP" then
            score = hp
        elseif priority == "Nearest" then
            score = worldDist
        else
            score = screenDist
        end

        if score < bestScore then
            bestScore = score
            best = player
        end
    end

    return best
end

-- ========== WALLBANG ENGINE ==========
local wbParts = {}
local wbConn = nil

local function isCharacterPart(inst)
    for _, p in ipairs(Players:GetPlayers()) do
        if p.Character and inst:IsDescendantOf(p.Character) then
            return true
        end
    end
    return false
end

function enableWB()
    for _, v in ipairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") and not isCharacterPart(v) then
            pcall(function()
                if v.CanQuery then
                    wbParts[v] = true
                    v.CanQuery = false
                end
            end)
        end
    end
    wbConn = workspace.DescendantAdded:Connect(function(v)
        taskLib.wait()
        if v:IsA("BasePart") and not isCharacterPart(v) then
            pcall(function()
                v.CanQuery = false
                wbParts[v] = true
            end)
        end
    end)
end

function disableWB()
    if wbConn then wbConn:Disconnect(); wbConn = nil end
    for v in pairs(wbParts) do
        pcall(function()
            if v and v.Parent then v.CanQuery = true end
        end)
    end
    wbParts = {}
end

-- ========== FLY ENGINE ==========
local flyBV, flyBG = nil, nil

function enableFly()
    local ch = LP.Character
    local root = ch and ch:FindFirstChild("HumanoidRootPart")
    if not root then return end
    local hm = ch:FindFirstChildOfClass("Humanoid")
    if hm then hm.PlatformStand = true end

    flyBV = Instance.new("BodyVelocity", root)
    flyBV.Velocity = Vector3.zero
    flyBV.MaxForce = Vector3.new(1e9, 1e9, 1e9)

    flyBG = Instance.new("BodyGyro", root)
    flyBG.MaxTorque = Vector3.new(1e9, 1e9, 1e9)
    flyBG.P = 1e4
    flyBG.CFrame = root.CFrame
end

function disableFly()
    if flyBV then flyBV:Destroy(); flyBV = nil end
    if flyBG then flyBG:Destroy(); flyBG = nil end
    local ch = LP.Character
    local hm = ch and ch:FindFirstChildOfClass("Humanoid")
    if hm then hm.PlatformStand = false end
end

