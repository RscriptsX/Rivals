if not GUI.Parent or not GUI.Parent:IsA("CoreGui") then GUI.Parent=LP:WaitForChild("PlayerGui") end

local notifStack = 0
local function Notify(title,text,dur,col)
    notifStack += 1
    local idx = notifStack
    local n=mk("Frame",{Size=UDim2.new(0,260,0,56),Position=UDim2.new(1,10,1,-(idx*64)),BackgroundColor3=C.bg2,BackgroundTransparency=0},GUI); cr(8,n); stroke(n,C.bord,1)
    local bar=mk("Frame",{Size=UDim2.new(0,3,1,-8),Position=UDim2.new(0,4,0,4),BackgroundColor3=col or C.acc2},n); cr(2,bar)
    mk("TextLabel",{BackgroundTransparency=1,Text=title,Size=UDim2.new(1,-18,0,22),Position=UDim2.new(0,14,0,4),Font=Enum.Font.GothamBold,TextSize=13,TextColor3=C.txt,TextXAlignment=Enum.TextXAlignment.Left},n)
    mk("TextLabel",{BackgroundTransparency=1,Text=text,Size=UDim2.new(1,-18,0,22),Position=UDim2.new(0,14,0,26),Font=Enum.Font.Gotham,TextSize=11,TextColor3=C.sub,TextXAlignment=Enum.TextXAlignment.Left,TextWrapped=true},n)
    tw(n,.3,{Position=UDim2.new(1,-268,1,-(idx*64))})
    task.delay(dur or 4,function()
        tw(n,.3,{Position=UDim2.new(1,10,1,-(idx*64))})
        task.wait(.35); n:Destroy(); notifStack-=1
    end)
end

